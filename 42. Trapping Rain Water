class Solution(object):
    def trap(self, height):
        left_wall = 0
        right_wall = 0
        max_left = []
        max_right = []
        n = len(height)
        for i in range(n):
            j= -i-1
            max_left.append(left_wall)
            max_right.append(right_wall)
            left_wall = max(left_wall, height[i])
            right_wall = max(right_wall, height[j])
        max_right.reverse()
        sum_arr = 0
        for i in range(n):
            potential = min(max_left[i],max_right[i])
            sum_arr += max(0, potential - height[i])
        return sum_arr

        
