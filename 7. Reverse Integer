class Solution(object):
    def reverse(self, x):
        if x < 0:
            sign = -1
        else:
            sign = 1
        x=abs(x)
        rev = 0
        while x:
            rev = rev * 10 + x % 10
            x //= 10
        rev*=sign
        if rev > (2**31-1) or rev < (-2**31):
            return 0
        return rev
