class Solution(object):
    def threeSum(self, nums):
        nums.sort()
        x = len(nums)
        sol = []
        for i in range(x - 2):
            if i > 0 and nums[i] == nums[i - 1]:
                continue
            j = i + 1
            k = x - 1
            while j < k:
                sum_total = nums[i] + nums[j] + nums[k]
                if sum_total == 0:
                    sol.append([nums[i], nums[j], nums[k]])
                    j += 1
                    k -= 1
                    while j < k and nums[j] == nums[j - 1]:
                        j += 1
                    while j < k and nums[k] == nums[k + 1]:
                        k -= 1
                elif sum_total < 0:
                    j += 1
                else:
                    k -= 1
        return sol
