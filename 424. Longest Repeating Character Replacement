class Solution(object):
    def characterReplacement(self, s, k):
        count= {}
        n=len(s)
        l=0
        maxfreq=0
        ans=0
        for r in range(n):
            count[s[r]] = count.get(s[r],0) + 1
            maxfreq=max(count[s[r]], maxfreq)
            while(r-l+1) - maxfreq > k:
                count[s[l]]-=1
                l+=1
            ans=max(ans,r-l+1)
        return ans
        
