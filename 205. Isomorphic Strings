class Solution(object):
    def isIsomorphic(self, s, t):
        """
        :type s: str
        :type t: str
        :rtype: bool
        """
        mapped={}
        seen=set()
        for i,j in zip(s,t):
            if i in mapped:
                if mapped[i] != j:
                    return False
            else:
                if j in seen:
                    return False
            mapped[i]=j
            seen.add(j)
        return True
