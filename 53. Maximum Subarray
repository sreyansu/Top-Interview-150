class Solution(object):
    def maxSubArray(self, num):
        """
        :type nums: List[int]
        :rtype: int
        """
        max_subarr = num[0]
        curr_max = num[0]
        for i in range(1,len(num)):
            curr_max= max(num[i], curr_max + num[i])
            max_subarr = max(max_subarr, curr_max)
        return max_subarr
