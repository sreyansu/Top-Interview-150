class Solution(object):
    def merge(self, num1, m, num2, n):
        """
        :type nums1: List[int]
        :type m: int
        :type nums2: List[int]
        :type n: int
        :rtype: None Do not return anything, modify nums1 in-place instead.
        """
        i=m-1
        j=n-1
        k=m+n-1
        while i>=0 and j >= 0:
            if num1[i] > num2[j]:
                num1[k]=num1[i]
                i-=1
            else:
                num1[k]=num2[j]
                j-=1
            k-=1
        while j>=0:
            num1[k]=num2[j]
            j-=1
            k-=1
