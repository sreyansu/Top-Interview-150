class Solution(object):
    def generateParenthesis(self, n):
        res = []
        def backtR(curr, open_count, close_count):
            if len(curr) == 2 * n:
                res.append(curr)
                return
            if open_count < n:
                backtR(curr + "(", open_count + 1, close_count)
            if close_count < open_count:
                backtR(curr + ")", open_count, close_count + 1)
        backtR("", 0, 0)
        return res
